{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tldr-app",
  "version": "0.3.0",
  "identifier": "com.user.tldr-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tldr-app",
        "width": 800,
        "height": 600,
        "visible": false,
        "dragDropEnabled": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/firancly/tldr-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzQjI0MjMyODQzQTJDRkYKUldUL0xEcUVNa0t5azNRbkd6QW96cnJWWWg3TlFnL2J0bXlCS2lScmVERHJURWUwZEpScDVBOUIK"
    }
  }
}
